{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/auth/register",
      "destination": "/api/auth?__op=register"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth?__op=login"
    },
    {
      "source": "/api/auth/logout",
      "destination": "/api/auth?__op=logout"
    },
    {
      "source": "/api/auth/refresh",
      "destination": "/api/auth?__op=refresh"
    },
    {
      "source": "/api/auth/forgot-password",
      "destination": "/api/auth?__op=forgot-password"
    },
    {
      "source": "/api/auth/reset-password",
      "destination": "/api/auth?__op=reset-password"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/auth?__op=me"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/auth.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
