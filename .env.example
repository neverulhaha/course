# Frontend (Vite)
VITE_API_BASE_URL=/api

# Optional: when running `vite` alone, proxy API to `vercel dev` (see vite.config.ts)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# ── Vercel / api/auth serverless (Project → Settings → Environment Variables) ──
# • Rewrites: /api/auth/* → api/auth.ts?__op=* ; SPA: /auth/*, /app/* → index.html (React Router)
# • FRONTEND_URL = точный Origin прод-фронта (https://your-app.vercel.app), без слэша в конце — для CORS

# Рекомендация: для сложных транзакций иногда надёжнее Direct (5432), не Transaction pooler (6543).
# См. Supabase → Settings → Database → Connection string (URI).
# Пароль в URI без квадратных скобок; спецсимволы — через percent-encoding (например @ → %40).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

JWT_ACCESS_SECRET=change-me-long-random-secret
JWT_REFRESH_PEPPER=

# ACCESS_TOKEN_TTL_MINUTES — срок access JWT; PASSWORD_RESET_TTL_HOURS — срок ссылки сброса; REFRESH_TOKEN_TTL_DAYS — refresh в БД
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_HOURS=1

DEFAULT_USER_ROLE=user

# Локально: http://localhost:5173 | Прод: https://<project>.vercel.app (как в браузере)
FRONTEND_URL=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
