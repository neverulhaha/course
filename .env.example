VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI generation is forced to OpenRouter free models only.
# Paid model envs such as AI_MODEL, OPENROUTER_MODEL and OPENAI_MODEL are intentionally ignored by Edge Functions.
OPENROUTER_API_KEY=
OPENROUTER_FREE_MODEL=openai/gpt-oss-120b:free
# Alternative free-only override: AI_FREE_MODEL=openrouter/free or any OpenRouter model id ending with :free
AI_FREE_MODEL=
OPENROUTER_SITE_URL=https://course-rosy.vercel.app
OPENROUTER_APP_NAME=Diplom Course Generator
# Leave false by default for better compatibility with free OpenRouter models.
AI_USE_RESPONSE_FORMAT=false

MIN_SOURCE_LENGTH=700
MAX_SOURCE_CHARS=120000
QA_MAX_SOURCE_CHARS=12000
