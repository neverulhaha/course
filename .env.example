# Frontend (Vite)
VITE_API_BASE_URL=/api

# Optional: when running `vite` alone, proxy API to `vercel dev` (see vite.config.ts)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# ── Vercel / api/auth serverless (set in Vercel Project → Environment Variables) ──
# Auth routes: single function api/auth.ts; vercel.json rewrites /api/auth/* → ?__op=...

# Рекомендация: для сложных транзакций иногда надёжнее Direct (5432), не Transaction pooler (6543).
# См. Supabase → Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

JWT_ACCESS_SECRET=change-me-long-random-secret
JWT_REFRESH_PEPPER=

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_HOURS=1

DEFAULT_USER_ROLE=user

FRONTEND_URL=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
