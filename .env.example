# Разрешённые переменные окружения (Vercel / локально).
# Код и сборка читают только их (и служебные вроде NODE_ENV от платформы).

# ── Фронт (Origin для CORS у serverless API) ──
FRONTEND_URL=http://localhost:5173

# ── Supabase: клиент Vite (сборка) — хотя бы одна пара URL + anon/publishable ──
VITE_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PUBLISHABLE_OR_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PUBLISHABLE_OR_ANON_KEY=

# Секреты только на сервере / в CI (в браузерный бандл не попадают)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# ── Postgres (строка подключения для serverless API): достаточно одной из URL ──
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Обычно подставляет интеграция Vercel+Supabase (для справки; сборка URI в коде не делается)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_HOST=

# ── JWT кастомного /api/auth (как JWT Secret в Supabase) ──
SUPABASE_JWT_SECRET=

# Срок access-токена: либо часы, либо минуты (если заданы оба — приоритет у часов)
ACCESS_TOKEN_TTL_HOURS=
ACCESS_TOKEN_TTL_MINUTES=15

# ── AI generation for Supabase Edge Functions ──
# Вариант OpenRouter/OpenAI-compatible. Не хранить реальные ключи в git.
AI_PROVIDER=openrouter
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://course-rosy.vercel.app
OPENROUTER_APP_NAME=Diplom Course Generator
AI_USE_RESPONSE_FORMAT=true

# Fallback для OpenAI, если AI_* не заданы
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

MIN_SOURCE_LENGTH=700
